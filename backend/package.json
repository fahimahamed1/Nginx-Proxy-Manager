{
  "name": "nginx-proxy-manager-modern-backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outdir=dist",
    "start": "node dist/index.js",
    "db:check": "echo 'Note: DB migration runs automatically at startup via src/db/migrate.ts (raw SQL).'",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@hono/zod-validator": "^0.4.3",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.3",
    "handlebars": "^4.7.8",
    "hono": "^4.7.4",
    "jose": "^6.0.8",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.19.17",
    "drizzle-kit": "^0.30.4",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
